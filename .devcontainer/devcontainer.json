{
  "name": "indieweb-endpoints-ruby",
  "image": "git.jgarber.cc/devcontainers/images/ruby:4.0.5",
  "features": {
    "git.jgarber.cc/devcontainers/features/bundler-cache:0": {}
  },
  "runArgs": ["--name", "indieweb-endpoints-ruby"],
  "updateContentCommand": "bundle install",
  "customizations": {
